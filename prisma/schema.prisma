generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id                 String           @id @default(cuid())
  clerkId            String           @unique
  username           String           @unique
  birthdate          DateTime?

  // Onboarding profiling fields
  howDidYouHear      String?          // "youtube", "friend", "google", "university", "other"
  currentRole        String?          // "student", "developer", "it_professional", "other"
  educationLevel     String?          // "high_school", "undergraduate", "graduate", "self_taught"
  learningGoals      String[]         // ["web_hacking", "network_security", "malware_analysis", etc.]

  // Onboarding state
  onboardingComplete Boolean          @default(false)
  onboardingStep     Int              @default(0)

  // Profile metadata
  avatarUrl          String?
  bio                String?
  country            String?          @default("Ethiopia")
  xpPoints           Int              @default(0)
  cpBalance          Int              @default(50)
  // New users get 50 CP welcome bonus
  currentStreak      Int              @default(0)
  longestStreak      Int              @default(0)
  lastActivityAt     DateTime?
  emailNotifications Boolean          @default(true)
  weeklyActivity     Json?
  level              Int              @default(1)
  skillProgress      Json?

  // Timestamps
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relations
  enrollments        Enrollment[]
  certificates       Certificate[]
  progress           LessonProgress[]

  @@map("user_profiles")
}

model CPTransaction {
  id          String            @id @default(cuid())
  userId      String            // Clerk userId

  type        CPTransactionType
  amount      Int               // CP amount (positive=credit, negative=debit)

  // For purchases
  packageId   String?           // Which package they bought
  amountPaid  Float?            // ETB paid
  currency    String?           @default("ETB")
  chapaRef    String?           @unique

  // For unlocks
  moduleId    String?           // Sanity module _id
  courseId    String?           // Sanity course _id

  description String?
  createdAt   DateTime          @default(now())

  @@map("cp_transactions")
}

model ModuleUnlock {
  id         String   @id @default(cuid())
  userId     String   // Clerk userId (not profile id)
  moduleId   String   // Sanity module _id
  courseId   String   // Sanity course _id
  cpSpent    Int      // How many CP were spent
  unlockedAt DateTime @default(now())

  @@unique([userId, moduleId])
  @@map("module_unlocks")
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String           // Sanity course _id (string reference, not a DB foreign key)

  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  // Payment reference
  paymentId   String?
  amountPaid  Float?
  currency    String?          @default("ETB")

  user        UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id          String      @id @default(cuid())
  userId      String
  lessonId    String      // Sanity lesson _id (string reference)
  courseId    String      // Sanity course _id (string reference)

  completed   Boolean     @default(false)
  completedAt DateTime?
  xpEarned    Int         @default(0)

  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Certificate {
  id              String      @id @default(cuid())
  userId          String
  courseId        String      // Sanity course _id

  certificateCode String      @unique @default(cuid())
  issuedAt        DateTime    @default(now())
  pdfUrl          String?

  // Payment for cert
  paid            Boolean     @default(false)
  paymentId       String?
  paymentType     String?     @default("cp")

  user            UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Payment {
  id             String        @id @default(cuid())
  userId         String        // Clerk user ID directly
  courseId       String?       // Sanity course _id (null for cert payments)

  chapaReference String?       @unique
  amount         Float
  currency       String        @default("ETB")
  status         PaymentStatus @default(PENDING)
  type           PaymentType   @default(COURSE)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("payments")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentType {
  COURSE
  CERTIFICATE
  SUBSCRIPTION
}

enum CPTransactionType {
  PURCHASE
  MODULE_UNLOCK
  WELCOME_BONUS
  BONUS
  REFUND
}
